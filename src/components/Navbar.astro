---
---
<!-- Skip to main content link for accessibility and SEO -->
<a href="#main-content" class="sr-only focus:not-sr-only">Saltar a contenido principal</a>

<nav class="fixed top-0 left-0 w-full h-[80px] z-50 transition-all duration-300" id="navbar" aria-label="Navegación principal">
    <div class="max-w-[1200px] mx-auto px-[5%] h-full flex justify-between items-center">
        <a href="/" class="logo text-text flex items-center gap-1 text-3xl font-heading font-semibold tracking-tight" aria-label="Oncogorro - Inicio">
            <span class="text-[#A5C94B]">Onco</span><span class="font-bold text-[#5DA5DA] drop-shadow-sm">gorro</span>
        </a>
        <div class="nav-links hidden lg:flex gap-10">
            <a href="#inicio" class="font-medium text-text-light hover:text-primary relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-0.5 after:bg-primary after:transition-all hover:after:w-full">Inicio</a>
            <a href="#historia" class="font-medium text-text-light hover:text-primary relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-0.5 after:bg-primary after:transition-all hover:after:w-full">Historia</a>
            <a href="#soluciones" class="font-medium text-text-light hover:text-primary relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-0.5 after:bg-primary after:transition-all hover:after:w-full">Soluciones</a>
            <a href="#investigacion" class="font-medium text-text-light hover:text-primary relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-0.5 after:bg-primary after:transition-all hover:after:w-full">I+D</a>
            <a href="#faq" class="font-medium text-text-light hover:text-primary relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-0.5 after:bg-primary after:transition-all hover:after:w-full">FAQ</a>
        </div>
        <a href="https://wa.me/51948096075" target="_blank" rel="noopener noreferrer" class="btn btn-outline hidden lg:inline-flex">Contáctanos</a>
        <button class="menu-toggle lg:hidden bg-transparent border-none text-2xl text-text cursor-pointer" aria-label="Abrir menú de navegación" aria-expanded="false">
            <i class="ph ph-list" aria-hidden="true"></i>
        </button>
    </div>
    
    <!-- Mobile Menu -->
    <div class="mobile-menu absolute top-[80px] left-0 w-full bg-white/98 backdrop-blur-xl shadow-xl border-t border-black/5 lg:hidden opacity-0 pointer-events-none -translate-y-4 transition-all duration-300 ease-in-out z-40" id="mobile-menu">
        <div class="px-[5%] py-8 flex flex-col gap-6">
            <a href="#inicio" class="font-medium text-text hover:text-primary transition-colors py-2 border-b border-black/5">Inicio</a>
            <a href="#historia" class="font-medium text-text hover:text-primary transition-colors py-2 border-b border-black/5">Historia</a>
            <a href="#soluciones" class="font-medium text-text hover:text-primary transition-colors py-2 border-b border-black/5">Soluciones</a>
            <a href="#investigacion" class="font-medium text-text hover:text-primary transition-colors py-2 border-b border-black/5">I+D</a>
            <a href="#faq" class="font-medium text-text hover:text-primary transition-colors py-2 border-b border-black/5">FAQ</a>
            <a href="https://wa.me/51948096075" target="_blank" rel="noopener noreferrer" class="btn btn-primary text-center mt-4">Contáctanos</a>
        </div>
    </div>
</nav>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const navbar = document.getElementById('navbar');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuToggle = document.querySelector('.menu-toggle');
        let isMenuOpen = false;

        if (!navbar || !mobileMenu || !menuToggle) return;

        // Scroll effect
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                navbar.classList.add('bg-[#FDFBF7]/90', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-[#C88C95]/10');
            } else {
                navbar.classList.remove('bg-[#FDFBF7]/90', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-[#C88C95]/10');
            }
        });

        // Mobile menu toggle
        menuToggle.addEventListener('click', () => {
            isMenuOpen = !isMenuOpen;
            if (isMenuOpen) {
                mobileMenu.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-4');
                mobileMenu.classList.add('translate-y-0', 'pointer-events-auto');
                menuToggle?.setAttribute('aria-expanded', 'true');
                if (menuToggle) menuToggle.innerHTML = '<i class="ph ph-x" aria-hidden="true"></i>';
            } else {
                mobileMenu.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
                mobileMenu.classList.remove('translate-y-0', 'pointer-events-auto');
                menuToggle?.setAttribute('aria-expanded', 'false');
                if (menuToggle) menuToggle.innerHTML = '<i class="ph ph-list" aria-hidden="true"></i>';
            }
        });

        // Close menu when clicking on links
        mobileMenu.addEventListener('click', (e) => {
            const target = e.target as HTMLElement | null;
            if (target && target.tagName === 'A') {
                isMenuOpen = false;
                mobileMenu.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
                mobileMenu.classList.remove('translate-y-0', 'pointer-events-auto');
                menuToggle?.setAttribute('aria-expanded', 'false');
                if (menuToggle) menuToggle.innerHTML = '<i class="ph ph-list" aria-hidden="true"></i>';
            }
        });

        // Close menu on resize to desktop
        window.addEventListener('resize', () => {
            if (window.innerWidth >= 1024) {
                isMenuOpen = false;
                mobileMenu.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
                mobileMenu.classList.remove('translate-y-0', 'pointer-events-auto');
                menuToggle?.setAttribute('aria-expanded', 'false');
                if (menuToggle) menuToggle.innerHTML = '<i class="ph ph-list" aria-hidden="true"></i>';
            }
        });
    });
</script>

<style>
    /* Screen reader only class */
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
    }
    
    .focus\:not-sr-only:focus {
        position: static;
        width: auto;
        height: auto;
        padding: inherit;
        margin: inherit;
        overflow: visible;
        clip: auto;
        white-space: normal;
    }
</style>
