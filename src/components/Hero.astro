<section class="min-h-screen pt-32 lg:pt-[120px] pb-16 lg:pb-[60px] px-[5%] grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 max-w-[1200px] mx-auto items-center text-center lg:text-left hero" id="inicio">
    <div class="max-w-[600px] mx-auto lg:mx-0">
        <span class="fade-up inline-block px-4 py-2 bg-primary-light text-primary-dark rounded-full text-xs font-semibold tracking-wider uppercase mb-6">Acompañamiento Oncológico</span>
        <h1 class="fade-up delay-[100ms] text-[clamp(2rem,3.5vw,3.5rem)] tracking-tight leading-tight">Soluciones de <span class="highlight">enfriamiento capilar</span> para conservar tu cabello durante la quimioterapia</h1>
        <p class="fade-up delay-[200ms] mt-6 mb-10 text-[1.125rem] text-text-light leading-relaxed">En Oncogorro desarrollamos soluciones accesibles de enfriamiento capilar para pacientes oncológicos.</p>
        <div class="fade-up delay-[300ms] flex flex-wrap gap-4 justify-center lg:justify-start">
            <a href="https://wa.me/51948096075" target="_blank" rel="noopener noreferrer" class="btn btn-primary text-lg px-8 py-3">
                <i class="ph ph-whatsapp-logo text-xl"></i> Hablar por WhatsApp
            </a>
        </div>
    </div>
    <div class="relative fade-up delay-[400ms] flex justify-center w-full">
        <!-- Removed overflow-hidden from glass-panel so absolute badges can break out freely -->
        <div class="glass-panel relative p-4 bg-white/70">
            <img src="/assets/hero_model_new.jpg" alt="Mujer sonriendo usando gorro de enfriamiento capilar para quimioterapia - Oncogorro" class="rounded-[16px] w-[90%] md:w-full max-w-[450px] mx-auto h-auto object-cover aspect-[4/5] relative z-10 loading-lazy" width="450" height="563">
            <!-- Ensure badges have a higher z-index to stay above the image and container -->
            <div class="absolute top-4 md:top-8 -right-2 md:-right-4 lg:-right-10 bg-white/95 backdrop-blur-md px-3 py-2 md:px-5 md:py-3 rounded-full flex items-center gap-2 text-sm md:text-base font-medium shadow-lg z-20 animate-[float_6s_ease-in-out_infinite_0s] text-text whitespace-nowrap">
                <i class="ph-fill ph-heart text-primary text-lg md:text-xl"></i>
                <span>Comodidad Absoluta</span>
            </div>
            <div class="absolute bottom-8 md:bottom-12 -left-2 md:-left-4 lg:-left-10 bg-white/95 backdrop-blur-md px-3 py-2 md:px-5 md:py-3 rounded-full flex items-center gap-2 text-sm md:text-base font-medium shadow-lg z-20 animate-[float_6s_ease-in-out_infinite_3s] text-text whitespace-nowrap">
                <i class="ph-fill ph-shield-check text-primary text-lg md:text-xl"></i>
                <span>Diseño Terapéutico</span>
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
        100% { transform: translateY(0px); }
    }
</style>
