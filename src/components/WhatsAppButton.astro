---
---

<div class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-1 group">
  <!-- Dialogue Bubble / Tooltip -->
  <div class="bg-white px-3 py-1.5 rounded-xl shadow-xl border border-black/5 mb-0.5 animate-bounce-slow md:opacity-0 md:group-hover:opacity-100 transition-all duration-300 pointer-events-none md:translate-y-2 md:group-hover:translate-y-0 relative">
    <p class="text-[11px] md:text-xs font-bold text-primary whitespace-nowrap mb-0 leading-none">¡Escríbenos!</p>
    <!-- Triangle arrow for bubble -->
    <div class="absolute -bottom-1 right-5 w-2 h-2 bg-white rotate-45 border-r border-b border-black/5"></div>
  </div>

  <!-- WhatsApp Button -->
  <a
    href="https://wa.me/51948096075?text=Hola%2C%20me%20gustar%C3%ADa%20recibir%20m%C3%A1s%20informaci%C3%B3n%20sobre%20los%20kits%20de%20enfriamiento%20capilar."
    target="_blank"
    rel="noopener noreferrer"
    class="relative flex items-center justify-center w-14 h-14 md:w-16 md:h-16 bg-[#25D366] text-white rounded-full shadow-[0_10px_25px_-5px_rgba(37,211,102,0.4)] hover:shadow-[0_15px_30px_-5px_rgba(37,211,102,0.6)] hover:-translate-y-1 active:scale-95 transition-all duration-300 hover:no-underline"
    aria-label="Contactar por WhatsApp"
    title="Chatear por WhatsApp"
  >
    <!-- Pulse Effect -->
    <span class="absolute inset-0 rounded-full bg-[#25D366] opacity-40 animate-ping-slow"></span>
    
    <!-- Icon -->
    <i class="ph-fill ph-whatsapp-logo text-3xl md:text-4xl relative z-10"></i>
  </a>
</div>

<style>
  @keyframes ping-slow {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    70%, 100% {
      transform: scale(1.6);
      opacity: 0;
    }
  }
  .animate-ping-slow {
    animation: ping-slow 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  @keyframes bounce-slow {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }
  .animate-bounce-slow {
    animation: bounce-slow 3s ease-in-out infinite;
  }
</style>
