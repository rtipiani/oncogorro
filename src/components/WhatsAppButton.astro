---

<div class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3 group">
  <!-- Tooltip/Message -->
  <div class="bg-white px-4 py-2 rounded-xl shadow-lg border border-black/5 mb-1 opacity-0 group-hover:opacity-100 transition-all duration-300 pointer-events-none hidden md:block translate-y-2 group-hover:translate-y-0">
    <p class="text-sm font-medium text-slate-700">¿Necesitas ayuda? ¡Escríbenos!</p>
  </div>

  <!-- WhatsApp Button -->
  <a
    href="https://wa.me/51948096075"
    target="_blank"
    rel="noopener noreferrer"
    class="relative flex items-center justify-center w-14 h-14 md:w-16 md:h-16 bg-[#25D366] text-white rounded-full shadow-[0_10px_25px_-5px_rgba(37,211,102,0.4)] hover:shadow-[0_15px_30px_-5px_rgba(37,211,102,0.6)] hover:-translate-y-1 active:scale-95 transition-all duration-300 hover:no-underline"
    aria-label="Contactar por WhatsApp"
    title="Chatear por WhatsApp"
  >
    <!-- Pulse Effect -->
    <span class="absolute inset-0 rounded-full bg-[#25D366] opacity-40 animate-ping-slow"></span>
    
    <!-- Icon -->
    <i class="ph-fill ph-whatsapp-logo text-3xl md:text-4xl relative z-10"></i>
  </a>
</div>

<style>
  @keyframes ping-slow {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    70%, 100% {
      transform: scale(1.6);
      opacity: 0;
    }
  }
  .animate-ping-slow {
    animation: ping-slow 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
</style>
