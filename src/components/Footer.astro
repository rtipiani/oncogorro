<section class="py-16 md:py-20 px-[5%] bg-gradient-to-br from-primary-light to-bg" id="contacto">
    <div class="glass-panel max-w-[800px] mx-auto p-6 md:p-10 lg:p-16 text-center fade-up w-full">
        <h2 class="text-3xl md:text-4xl font-heading font-semibold mb-4">Acompañamos tu Tratamiento Oncológico</h2>
        <p class="text-base md:text-lg text-text-light mb-8 px-2 md:px-0">Estamos aquí para escucharte y ayudarte a encontrar el kit de enfriamiento capilar perfecto para ti. Tu fuerza nos inspira.</p>
        <div class="mt-8 flex w-full justify-center">
            <a href="https://wa.me/51948096075?text=Hola%2C%20me%20gustar%C3%ADa%20recibir%20m%C3%A1s%20informaci%C3%B3n%20sobre%20los%20kits%20de%20enfriamiento%20capilar." target="_blank" rel="noopener noreferrer" class="btn btn-primary text-sm md:text-base py-2 md:py-3 px-5 md:px-8 w-full sm:w-auto shadow-md hover:no-underline">
                <i class="ph ph-whatsapp-logo text-xl" aria-hidden="true"></i> Hablemos por WhatsApp
            </a>
        </div>
    </div>
</section>

<footer class="bg-white border-t border-black/5 relative overflow-hidden">
    <!-- Subtle background gradient accent -->
    <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 blur-[120px] rounded-full pointer-events-none -translate-y-1/2 translate-x-1/3"></div>

    <div class="max-w-[1200px] mx-auto px-[5%] pt-12 md:pt-20 pb-12 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
            <!-- Brand Column -->
            <div class="flex flex-col items-center md:items-start justify-start">
                <a href="/" class="inline-block hover:no-underline" aria-label="Oncogorro - Inicio">
                    <img src="/assets/logo2.jpeg" alt="Oncogorro" class="w-full max-w-[200px] h-auto object-contain" />
                </a>
            </div>

            <!-- Description Column -->
            <div class="flex flex-col justify-start items-center md:items-start text-center md:text-left">
                <p class="text-[1.05rem] text-text-light leading-relaxed md:pr-4 mt-2">
                    Desarrollamos soluciones accesibles de enfriamiento capilar para pacientes oncológicos, brindando acompañamiento especializado durante todo el tratamiento de quimioterapia.
                </p>
            </div>

            <!-- Links Column -->
            <nav class="flex flex-col items-center md:items-start text-center md:text-left" aria-label="Footer navigation">
                <h4 class="text-sm font-bold text-text uppercase tracking-widest mb-4 font-heading">Explorar</h4>
                <ul class="flex flex-col items-center md:items-start gap-2 md:gap-3">
                    <li><a href="/#inicio" class="text-[1.05rem] text-text-light hover:text-primary transition-colors inline-flex items-center gap-2 group hover:no-underline"><span class="w-1.5 h-1.5 rounded-full bg-primary/30 group-hover:bg-primary transition-colors"></span> Inicio</a></li>
                    <li><a href="/#historia" class="text-[1.05rem] text-text-light hover:text-primary transition-colors inline-flex items-center gap-2 group hover:no-underline"><span class="w-1.5 h-1.5 rounded-full bg-primary/30 group-hover:bg-primary transition-colors"></span> Nuestra Historia</a></li>
                    <li><a href="/#soluciones" class="text-[1.05rem] text-text-light hover:text-primary transition-colors inline-flex items-center gap-2 group hover:no-underline"><span class="w-1.5 h-1.5 rounded-full bg-primary/30 group-hover:bg-primary transition-colors"></span> Soluciones Oncogorro</a></li>
                    <li><a href="/#investigacion" class="text-[1.05rem] text-text-light hover:text-primary transition-colors inline-flex items-center gap-2 group hover:no-underline"><span class="w-1.5 h-1.5 rounded-full bg-primary/30 group-hover:bg-primary transition-colors"></span> Investigación y Desarrollo</a></li>
                    <li><a href="/#faq" class="text-[1.05rem] text-text-light hover:text-primary transition-colors inline-flex items-center gap-2 group hover:no-underline"><span class="w-1.5 h-1.5 rounded-full bg-primary/30 group-hover:bg-primary transition-colors"></span> Preguntas Frecuentes</a></li>
                </ul>
            </nav>

            <!-- Contact Column -->
            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <h4 class="text-sm font-bold text-text uppercase tracking-widest mb-4 font-heading">Contacto</h4>
                <div class="flex flex-col items-center md:items-start gap-4 md:gap-5">
                    <a href="https://wa.me/51948096075?text=Hola%2C%20me%20gustar%C3%ADa%20recibir%20m%C3%A1s%20informaci%C3%B3n%20sobre%20los%20kits%20de%20enfriamiento%20capilar." target="_blank" rel="noopener noreferrer" class="flex items-center md:items-start gap-4 text-text-light hover:text-primary transition-colors group flex-col md:flex-row hover:no-underline">
                        <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors shrink-0">
                            <i class="ph-fill ph-phone-call text-lg" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="text-xs text-text-light/70 uppercase tracking-wider mb-1">Llámanos o escríbenos</p>
                            <p class="font-medium text-[1.1rem]">+51 948 096 075</p>
                        </div>
                    </a>
                    
                    <a href="mailto:contacto@oncogorroperu.com" class="flex items-center md:items-start gap-4 text-text-light hover:text-primary transition-colors group flex-col md:flex-row hover:no-underline">
                        <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors shrink-0">
                            <i class="ph-fill ph-envelope-simple text-lg" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="text-xs text-text-light/70 uppercase tracking-wider mb-1">Correo Electrónico</p>
                            <p class="font-medium text-[1.1rem]">contacto@oncogorroperu.com</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <!-- Social Media Section (Intermedio) -->
        <div class="flex flex-col items-center justify-center mt-8 mb-16 px-[5%] w-full">
            <h4 class="text-[13px] font-bold text-text/80 uppercase tracking-[0.2em] mb-4 font-heading text-center">Síguenos en nuestras redes</h4>
            <div class="flex gap-5">
                <a href="https://wa.me/51948096075?text=Hola%2C%20me%20gustar%C3%ADa%20recibir%20m%C3%A1s%20informaci%C3%B3n%20sobre%20los%20kits%20de%20enfriamiento%20capilar." target="_blank" rel="noopener noreferrer" class="w-14 h-14 rounded-full bg-white border border-black/5 flex items-center justify-center text-text-light hover:bg-[#25D366] hover:text-white hover:border-[#25D366] hover:-translate-y-2 transition-all duration-300 shadow-md hover:shadow-lg hover:no-underline" aria-label="Chat with us on WhatsApp">
                    <i class="ph ph-whatsapp-logo text-2xl" aria-hidden="true"></i>
                </a>
                <a href="https://www.instagram.com/oncogorro.peru?igsh=MWJhMXpidHJuODFp&utm_source=qr" target="_blank" rel="noopener noreferrer" class="w-14 h-14 rounded-full bg-white border border-black/5 flex items-center justify-center text-text-light hover:bg-gradient-to-tr hover:from-[#F58529] hover:via-[#DD2A7B] hover:to-[#8134AF] hover:text-white hover:border-transparent hover:-translate-y-2 transition-all duration-300 shadow-md hover:shadow-lg hover:no-underline" aria-label="Visit us on Instagram">
                    <i class="ph ph-instagram-logo text-2xl" aria-hidden="true"></i>
                </a>
                <a href="https://www.facebook.com/share/1HNNc1PcAM/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer" class="w-14 h-14 rounded-full bg-white border border-black/5 flex items-center justify-center text-text-light hover:bg-[#1877F2] hover:text-white hover:border-[#1877F2] hover:-translate-y-2 transition-all duration-300 shadow-md hover:shadow-lg hover:no-underline" aria-label="Follow us on Facebook">
                    <i class="ph ph-facebook-logo text-2xl" aria-hidden="true"></i>
                </a>
            </div>
        </div>

        <!-- Bottom Copyright -->
        <div class="pt-8 border-t border-black/5 flex flex-col items-center gap-2 text-center">
            <span class="text-sm text-text-light/80 font-medium leading-none">
                &copy; 2026 Oncogorro. Todos los derechos reservados. | RUC: 20615282961
            </span>
        </div>
    </div>
</footer>
